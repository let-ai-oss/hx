{
  "name": "hx",
  "version": "76.2.1",
  "private": false,
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "bin": {
    "hx": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun --watch src/cli.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "bun test",
    "build": "mkdir -p ./dist && bun build ./src/cli.ts --compile --outfile ./dist/hx",
    "install:connect": "sh install-from-source.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "1.3.14",
    "eslint": "^10.6.0",
    "eslint-plugin-security": "^4.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  }
}
